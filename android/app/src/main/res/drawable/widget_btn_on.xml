<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow outer -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#2200E676"/>
        </shape>
    </item>
    <!-- Circle background -->
    <item
        android:top="4dp"
        android:bottom="4dp"
        android:left="4dp"
        android:right="4dp">
        <shape android:shape="oval">
            <solid android:color="#FF00E676"/>
        </shape>
    </item>
    <!-- Inner dot -->
    <item
        android:top="18dp"
        android:bottom="18dp"
        android:left="18dp"
        android:right="18dp">
        <shape android:shape="oval">
            <solid android:color="#FF00FF6A"/>
        </shape>
    </item>
</layer-list>
